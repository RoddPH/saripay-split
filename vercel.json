{
  "buildCommand": "cd playerguild && npm run build",
  "outputDirectory": "playerguild/build",
  "installCommand": "npm install && cd playerguild && npm install",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index.js"
    },
    {
      "source": "/((?!api).*)",
      "destination": "/index.html"
    }
  ]
}
